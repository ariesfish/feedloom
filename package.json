{
  "name": "@ariesfish/feedloom",
  "version": "0.1.0",
  "type": "module",
  "author": "ariesfish",
  "license": "MIT",
  "description": "Archive long-form web content as clean Markdown with local assets.",
  "homepage": "https://github.com/ariesfish/feedloom#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ariesfish/feedloom.git"
  },
  "bugs": {
    "url": "https://github.com/ariesfish/feedloom/issues"
  },
  "bin": {
    "feedloom": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "commander": "^14.0.0",
    "defuddle": "^0.18.1",
    "fast-xml-parser": "^5.0.0",
    "linkedom": "^0.18.12",
    "patchright": "^1.58.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
