{
  "name": "feedloom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "ariesfish",
  "description": "Archive long-form web content as clean Markdown with local assets.",
  "bin": {
    "feedloom": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "commander": "^14.0.0",
    "defuddle": "^0.18.1",
    "fast-xml-parser": "^5.0.0",
    "linkedom": "^0.18.12",
    "patchright": "^1.58.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
